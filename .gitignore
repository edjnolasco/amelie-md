# =========================
# Amelie MD — Clean Repo Policy
# =========================

# -------------------------
# Python core
# -------------------------
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Packaging / build
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# -------------------------
# Virtual environments
# -------------------------
.venv/
venv/
env/
ENV/

# -------------------------
# Testing / coverage
# -------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# -------------------------
# Type checking / lint
# -------------------------
.mypy_cache/
.ruff_cache/

# -------------------------
# IDE / Editor
# -------------------------
.vscode/
.idea/
*.swp
*.swo

# -------------------------
# OS noise
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# Logs
# -------------------------
*.log

# -------------------------
# Amelie MD — Generated artifacts (CRÍTICO)
# -------------------------

# Final outputs (core rule)
*.docx
*.pdf
*.html

# Output directory (default target)
outputs/

# Word temporary files
~$*

# Windows metadata
*.Zone.Identifier

# -------------------------
# Temporary analysis files
# -------------------------
tracked.txt
all.txt

# -------------------------
# Python packaging leftovers
# -------------------------
*.manifest
*.spec

# -------------------------
# Optional (keep commented if needed)
# -------------------------
# docs/_build/
# site/